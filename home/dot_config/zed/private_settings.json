// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "context_servers": {
    "mcp-server-linear": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
  },
  "agent_buffer_font_size": 13.0,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "default_config_options": {
        "mode": "acceptEdits",
      },
    },
  },
  "debugger": {
    "stepping_granularity": "statement",
  },
  "document_folding_ranges": "on",
  "which_key": {
    "enabled": false,
  },
  "lsp": {
    "oxlint": {
      "initialization_options": { "settings": { "typeAware": true } },
    },
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "preferences": {
            "preferTypeOnlyAutoImports": true,
          },
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "preferences": {
            "preferTypeOnlyAutoImports": true,
          },
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "tab_size": 2,
  "use_system_window_tabs": true,
  "unnecessary_code_fade": 0.5,
  "edit_predictions": {
    "mode": "subtle",
  },
  "edit_predictions_disabled_in": ["comment"],
  "agent": {
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
    "single_file_review": true,
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
    "show_merge_conflict_indicator": false,
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": true,
    "diagnostics": true,
  },
  "wrap_guides": [80],
  "use_smartcase_search": true,
  "seed_search_query_from_cursor": "selection",
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true,
  },
  "ui_font_family": ".SystemUIFont",
  "buffer_font_family": "Berkeley Mono",
  "buffer_font_size": 14.0,
  "buffer_line_height": "standard",
  "buffer_font_features": { "calt": 0 },
  "terminal": {
    "font_size": 14.0,
    "line_height": "standard",
  },
  "project_panel": {
    "entry_spacing": "standard",
  },
  "inlay_hints": {
    "show_value_hints": false,
  },
  "pane_split_direction_vertical": "right",
  "pane_split_direction_horizontal": "down",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Macchiato",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "tabs": {
    "file_icons": true,
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "autosave": "on_focus_change",

  // Extensions I use everywhere
  "auto_install_extensions": {
    "basher": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "colored-zed-icons-theme": true,
    "docker-compose": true,
    "dockerfile": true,
    "git-firefly": true,
    "sql": true,
    "toml": true,
    "xml": true,
  },
}
