[user]
email = {{ .email | quote }}
name = {{ .name | quote }}

[ui]
default-command = "log"
diff-editor = ":builtin"
diff-formatter = "difft"

[merge-tools.difft]
diff-args = ["--color=always", "$left", "$right"]

[revsets]
bookmark-advance-to = "@-"

[templates]
draft_commit_description = '''
concat(
  builtin_draft_commit_description,
  "JJ:",
  "\nJJ: ignore-rest\n",
  diff.git(),
)
'''
git_push_bookmark = '"afgomez/push-" ++ change_id.short()'
