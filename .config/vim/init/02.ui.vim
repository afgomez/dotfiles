" Colorscheme
"
syntax on
set termguicolors     " enable true colors support
let ayucolor="dark"
colorscheme ayu


" General UI
"
set number
set cursorline

set scrolloff=5      " Show some context when scrolling pages


set laststatus=2
set cmdheight=2


set signcolumn=yes   " Prevent the UI from jumping when showing gutter symbols

" Visual blocks
"
set virtualedit=block

" Wrap
"
set nowrap
set linebreak
set showbreak=↪
