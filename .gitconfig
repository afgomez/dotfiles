[include]
	path = ~/.gitconfig.local

[alias]
	co = checkout
	st = status

	ci = commit
	amend = commit --amend

	graph = log --graph --oneline
	mine = !"git log --author=$(git config --get user.email)"

[branch]
	autosetuprebase = always

[checkout]
	defaultremote = origin

[commit]
	verbose = true

[diff]
	algorithm = histogram

[pull]
	rebase = true
